[Unit]
Description=CorretorCenter
After=network.target postgresql.service

[Service]
Type=simple
WorkingDirectory=/home/ubuntu/CorretorCenter
EnvironmentFile=/home/ubuntu/CorretorCenter/.env
ExecStart=/usr/bin/node /home/ubuntu/CorretorCenter/app/server.js
Restart=always
RestartSec=5
User=ubuntu
Group=ubuntu

[Install]
WantedBy=multi-user.target
